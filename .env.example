VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Web Push (generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Set these only in Supabase Edge Function secrets (not in the client):
# VAPID_PUBLIC_KEY=same-as-above
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:admin@yourdomain.com
# PUSH_WEBHOOK_SECRET=optional-shared-secret-for-db-webhook
# SITE_URL=https://your-domain.com/Glory-Carriers

# After deploying send-push-notification, create a Supabase Database Webhook:
# Table: notifications | Event: INSERT | URL: /functions/v1/send-push-notification
